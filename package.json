{
  "name": "next-flow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prisma:generate": "prisma generate",
    "dev": "npm run dev:next",
    "dev:next": "next dev --webpack",
    "dev:trigger": "npx trigger.dev@latest dev --env-file .env",
    "build": "npm run prisma:generate && next build",
    "start": "npm run prisma:generate && next start",
    "lint": "eslint",
    "trigger:whoami": "npx trigger.dev@latest whoami",
    "trigger:env:prod": "npx trigger.dev@latest env list --env prod",
    "trigger:deploy:prod": "npx trigger.dev@latest deploy --env prod",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.2.3",
    "@google/generative-ai": "^0.24.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^6.19.3",
    "@trigger.dev/react-hooks": "^4.4.4",
    "@trigger.dev/sdk": "4.4.4",
    "@xyflow/react": "^12.10.2",
    "clsx": "^2.1.1",
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.5.0",
    "transloadit": "^4.10.0",
    "trigger.dev": "^4.4.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
